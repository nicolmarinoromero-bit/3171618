{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",

    "lib": ["DOM", "DOM.Iterable", "ESNext"],

    "strict": true,
    "skipLibCheck": true,

    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,

    "noEmit": true,
    "isolatedModules": true,
    "useDefineForClassFields": true
  },

  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}